DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# APP_URL: Comma-separated allowlist of frontend origins for CORS.
# Include production + staging + local URLs, no path/query needed.
# Example:
# APP_URL="https://theaestheticedit.com,https://staging.theaestheticedit.com,http://localhost:3000"
APP_URL="http://localhost:3000,http://localhost:5173"
# Allow requests with no Origin header (use true only for local scripts/smoke tests)
ALLOW_REQUESTS_WITHOUT_ORIGIN=false

# Firebase web app configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Server-side Firebase token verification key (usually same as VITE_FIREBASE_API_KEY)
FIREBASE_WEB_API_KEY=

# Admin configuration
# Preferred: bcrypt hash (salted)
# Generate with: node -e "require('bcrypt').hash('your_admin_password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=
# Legacy fallback (plain text, not recommended)
ADMIN_PASSWORD=
# TEMP migration switch only (do not keep true in production)
ALLOW_LEGACY_ADMIN_PASSWORD=false

# Email configuration (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=hello@theaestheticedit.com

# Environment
NODE_ENV=development
PORT=3000
JWT_SECRET=replace_this_with_a_long_random_secret_min_32_chars

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
